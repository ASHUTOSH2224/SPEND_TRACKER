APP_NAME=Spend Tracker API
APP_ENV=local
APP_DEBUG=true
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=spend_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=
SQLALCHEMY_ECHO=false
AUTH_SECRET_KEY=local-dev-secret-key-change-me
STATEMENT_SECRET_KEY=local-dev-statement-secret-key-change-me
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_PASSWORD_HASH_ITERATIONS=600000
STORAGE_BACKEND=local_fake
STORAGE_LOCAL_ROOT=.local_storage
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_BATCH_SIZE=10
LLM_PROVIDER_BACKEND=noop
